# Set by Convex after running `npm run convex:dev`.
NEXT_PUBLIC_CONVEX_URL=

# Optional server-side AI capture (BYOK text path en /api/ai/capture).
# La UI cae a reglas locales cuando falta. Esta ruta Next NO consume creditos
# del servidor: exige que el cliente envie su propia clave en el cuerpo (apiKey),
# por eso esta variable solo aplica al modo local/desarrollo, nunca a llamadas anonimas.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# ---------------------------------------------------------------------------
# TODAS las variables de abajo son OPCIONALES.
# Sin ninguna de ellas la app sigue funcionando por completo:
#   - el camino manual (capturar recibos/notas a mano) funciona,
#   - el login solo-con-contrasena (sin verificacion por correo) funciona.
# Cada bloque se "enciende" solo cuando defines sus claves.
# ---------------------------------------------------------------------------

# --- IA de vision (recibos via OpenRouter) ---------------------------------
# Se define en el entorno del DESPLIEGUE DE CONVEX (no en Next), porque la
# accion de vision corre en Convex y es la unica que cobra creditos con gate.
# Ausente => parseReceiptWithAI devuelve { ok:false, code:'ai_failed' } y la UI
# cae a la heuristica local; la app igual compila y el camino manual funciona.
OPENROUTER_API_KEY=
# Opcional. Modelo de OpenRouter a usar. Por defecto: google/gemini-2.0-flash-001
# (el multimodal de produccion mas barato que cumple). Puedes cambiarlo a un
# modelo ':free' o a qwen/qwen-2.5-vl-7b-instruct sin tocar codigo.
OPENROUTER_MODEL=

# --- Verificacion de correo en el registro/login (OTP por email) -----------
# Se definen en el entorno de Convex. Necesitas AMBAS para encender la
# verificacion por codigo. Ausentes => el auth degrada al flujo actual de
# solo-contrasena (sin OTP), que ya funciona.
RESEND_API_KEY=
# Remitente verificado en Resend, p. ej.: RindoMes <noreply@tudominio.com>
AUTH_EMAIL_FROM=

# --- Concesion de plan Pro para pruebas ------------------------------------
# Se define en el entorno de Convex. Habilita setHouseholdPlan (otorgar Pro
# manualmente, solo dueno) en entornos de prueba/desarrollo. Ausente o distinto
# de "true" => no se puede otorgar Pro manualmente; el checkout sigue siendo el
# stub honesto (sin exito falso). El cobro real futuro sera un webhook que llame
# a setHouseholdPlan, sin tocar mas codigo.
RINDOMES_ALLOW_TEST_GRANTS=
